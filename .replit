modules = ["java-graalvm22.3"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build Plugin"

[[workflows.workflow]]
name = "Build Plugin"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "mvn clean package -q && echo 'Build completed successfully at target/Xshards-1.2.5.jar'"

[workflows.workflow.metadata]
outputType = "console"
